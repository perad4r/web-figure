<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h4 mb-0">Sản phẩm</h1>
    <form class="d-flex gap-2" method="get" action="/san-pham">
      <input class="form-control form-control-sm" type="text" name="q" value="<%= q || '' %>" placeholder="Tìm kiếm..." />
      <button class="btn btn-sm btn-outline-primary" type="submit">Search</button>
    </form>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="alert alert-secondary">Chưa có sản phẩm.</div>
  <% } else { %>
    <div class="row g-3">
      <% products.forEach((p) => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <a class="text-decoration-none" href="/san-pham/<%= p.id %>">
            <div class="card h-100">
              <% if (p.hinh_anh) { %>
                <img class="card-img-top" src="<%= p.hinh_anh.startsWith('/') ? p.hinh_anh : ('/uploads/' + p.hinh_anh) %>" alt="" />
              <% } else { %>
                <div class="bg-light" style="height: 180px;"></div>
              <% } %>
              <div class="card-body">
                <div class="fw-semibold"><%= p.ten %></div>
                <div class="text-muted small"><%= p.theLoai ? p.theLoai.ten : '' %></div>
                <div class="mt-2"><%= Number(p.gia).toLocaleString('vi-VN') %> đ</div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('../partials/foot') %>
