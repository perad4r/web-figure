<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 720px;">
  <h1 class="h4 mb-3">New Category</h1>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/categories" class="vstack gap-2">
    <div>
      <label class="form-label">Name</label>
      <input class="form-control" name="ten" required />
    </div>
    <div>
      <label class="form-label">Description</label>
      <textarea class="form-control" name="mo_ta"></textarea>
    </div>
    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="trang_thai" value="1" checked />
      <label class="form-check-label">Active</label>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Create</button>
      <a class="btn btn-outline-secondary" href="/admin/categories">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
