<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-5">
  <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
    <i class="bi bi-cart3 fs-2 text-danger me-3"></i>
    <h1 class="h3 fw-bold mb-0 text-dark">Giỏ hàng của bạn</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger border-0 d-flex align-items-center rounded-3 shadow-sm">
      <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
      <div><%= error %></div>
    </div>
  <% } %>

  <% if (!items || items.length === 0) { %>
    <div class="alert alert-secondary border-0 bg-light text-center p-5 rounded-4 shadow-sm d-flex flex-column align-items-center justify-content-center py-5">
      <div class="bg-white rounded-circle p-4 mb-4 shadow-sm">
        <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
      </div>
      <h5 class="fw-medium text-dark mb-2">Giỏ hàng đang trống</h5>
      <p class="text-muted mx-auto mb-4" style="max-width: 400px;">Có vẻ như bạn chưa chọn sản phẩm nào. Hãy quay lại cửa hàng để tiếp tục mua sắm nhé!</p>
      <a href="/san-pham" class="btn pm-btn-red rounded-pill px-4 fw-bold shadow-sm transition hover-lift">Tiếp tục mua sắm</a>
    </div>
  <% } else { %>
    <div class="row g-5">
      <!-- Cart Items List -->
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
          <div class="card-header bg-white border-bottom pt-4 px-3 px-md-4">
            <div class="d-flex justify-content-between align-items-center pb-2">
                <h5 class="fw-bold mb-0 text-dark">Sản phẩm đã chọn (<%= items.length %>)</h5>
                <span class="text-muted d-none d-md-block fs-6">Đơn giá</span>
            </div>
          </div>
          
          <div class="card-body p-0">
            <div class="d-flex flex-column">
              <% items.forEach((it) => { %>
                <div class="p-3 p-md-4 border-bottom position-relative bg-white transition" onmouseover="this.style.backgroundColor='#f8f9fa'" onmouseout="this.style.backgroundColor='white'">
                  <div class="row align-items-center gy-3 m-0 cart-item-row" data-price="<%= it.variant?.gia || 0 %>">
                    
                    <!-- Product Image and Context -->
                    <div class="col-12 col-md-4 p-0 d-flex align-items-center">
                      <div class="bg-light rounded-4 p-2 me-3 text-muted d-flex align-items-center justify-content-center flex-shrink-0 border" style="width: 90px; height: 90px;">
                        <i class="bi bi-image fs-1 opacity-50"></i>
                      </div>
                      <div>
                        <h6 class="fw-bold text-dark mb-2 lh-base" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= it.variant?.product?.ten || 'Sản phẩm' %></h6>
                        <span class="badge bg-light text-secondary border px-2 py-1"><i class="bi bi-tag me-1"></i><%= it.variant?.ten || ('Tùy chọn #' + (it.variant?.id || '?')) %></span>
                        <!-- Mobile Unit Price -->
                        <div class="d-md-none fw-bold text-danger mt-2 fs-5"><%= Number(it.variant?.gia || 0).toLocaleString('vi-VN') %> đ</div>
                      </div>
                    </div>
                    
                    <!-- Desktop Unit Price -->
                    <div class="col-md-2 p-0 d-none d-md-flex justify-content-center align-items-center">
                      <div class="text-muted fw-medium fs-6"><%= Number(it.variant?.gia || 0).toLocaleString('vi-VN') %> <small class="text-decoration-underline">đ</small></div>
                    </div>
                    
                    <!-- Quantity Controls -->
                    <div class="col-7 col-md-3 p-0">
                      <form method="post" action="/giohangs/<%= it.id %>" class="m-0 app-quantity-form">
                        <input type="hidden" name="_method" value="PUT" />
                        <div class="input-group flex-nowrap rounded-pill border bg-light p-1 shadow-sm mx-md-auto" style="max-width: 150px; border-color: #dee2e6;">
                          <button class="btn border-0 rounded-circle p-0 d-flex align-items-center justify-content-center bg-white shadow-sm btn-decrease hover-lift transition" type="button" style="width: 36px; height: 36px; color: #495057;">
                            <i class="bi bi-dash fs-4 fw-bold"></i>
                          </button>
                          
                          <input class="form-control text-center border-0 fw-bold px-0 bg-transparent flex-grow-1 shadow-none" style="font-size: 1.15rem; min-width: 40px; color: #212529;" type="number" name="so_luong" min="1" value="<%= it.so_luong %>" title="Số lượng" autocomplete="off" />
                          
                          <button class="btn border-0 rounded-circle p-0 d-flex align-items-center justify-content-center bg-white shadow-sm btn-increase hover-lift transition" type="button" style="width: 36px; height: 36px; color: #495057;">
                            <i class="bi bi-plus fs-4 fw-bold"></i>
                          </button>
                        </div>
                      </form>
                    </div>

                    <!-- Actions and Subtotal -->
                    <div class="col-5 col-md-3 p-0 d-flex justify-content-end align-items-center gap-2 gap-md-3">
                      <!-- Desktop Subtotal -->
                      <div class="text-end fw-bold text-danger fs-5 d-none d-md-block flex-grow-1 item-subtotal">
                        <%= (Number(it.variant?.gia || 0) * Number(it.so_luong || 0)).toLocaleString('vi-VN') %> <small class="text-decoration-underline fs-6 mt-1">đ</small>
                      </div>
                      
                      <!-- Remove Button -->
                      <form method="post" action="/giohangs/<%= it.id %>" class="m-0 flex-shrink-0">
                        <input type="hidden" name="_method" value="DELETE" />
                        <button class="btn btn-light text-danger rounded-circle p-2 d-inline-flex align-items-center justify-content-center transition shadow-sm border border-light" type="submit" title="Xóa khỏi giỏ" style="width: 42px; height: 42px;" onmouseover="this.classList.replace('btn-light', 'btn-danger'); this.classList.replace('text-danger', 'text-white');" onmouseout="this.classList.replace('btn-danger', 'btn-light'); this.classList.replace('text-white', 'text-danger');">
                          <i class="bi bi-trash fs-5"></i>
                        </button>
                      </form>
                    </div>
                    
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          
          <div class="card-footer bg-light mt-0 pt-4 pb-4 px-3 px-md-4 border-top">
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-secondary fw-semibold fs-5">Tổng tiền giỏ hàng:</span>
              <span class="fs-3 fw-bold text-danger mb-0 cart-total"><%= Number(total || 0).toLocaleString('vi-VN') %> <small class="text-muted fs-5 align-text-top text-decoration-underline ms-1">đ</small></span>
            </div>
          </div>
        </div>
        
        <a href="/san-pham" class="btn btn-light text-dark fw-medium border shadow-sm rounded-pill px-4 py-2 transition hover-lift d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-2"></i> Tiếp tục mua sản phẩm khác
        </a>
      </div>

      <!-- Checkout Form -->
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 position-sticky" style="top: 2rem;">
          <h5 class="fw-bold mb-4 d-flex align-items-center"><i class="bi bi-card-checklist text-primary me-2"></i> Thông tin đặt hàng</h5>
          
          <form method="post" action="/giohangs/checkout" class="vstack gap-3">
            <div>
              <label class="form-label fw-semibold small text-muted text-uppercase mb-1">Họ tên người nhận</label>
              <input class="form-control bg-light border-0 px-3 py-2" name="ten_khach_hang" placeholder="Tên để nhận hàng" required />
            </div>
            
            <div>
              <label class="form-label fw-semibold small text-muted text-uppercase mb-1">Số điện thoại</label>
              <input class="form-control bg-light border-0 px-3 py-2" name="phone" type="tel" pattern="[0-9]{9,11}" title="Nhập 9-11 chữ số" placeholder="Ví dụ: 0912345678" required />
            </div>
            
            <div>
              <label class="form-label fw-semibold small text-muted text-uppercase mb-1">Địa chỉ giao hàng</label>
              <textarea class="form-control bg-light border-0 px-3 py-2" name="dia_chi" rows="2" placeholder="Số nhà, đường, phường/xã, quận/huyện, thành phố..." required></textarea>
            </div>
            
            <div>
              <label class="form-label fw-semibold small text-muted text-uppercase mb-1">Email <span class="fw-normal text-muted text-lowercase">(không bắt buộc)</span></label>
              <input class="form-control bg-light border-0 px-3 py-2" type="email" name="email" placeholder="Để nhận thông báo đơn hàng" />
            </div>
            
            <div>
              <label class="form-label fw-semibold small text-muted text-uppercase mb-1">Ghi chú đơn hàng</label>
              <textarea class="form-control bg-light border-0 px-3 py-2" name="ghi_chu" rows="2" placeholder="Ghi chú thêm về giao hàng (ví dụ: giao giờ hành chính...)"></textarea>
            </div>
            
            <hr class="my-2 border-light">
            
            <div class="d-flex justify-content-between mb-3 mt-1">
              <span class="text-dark fw-bold fs-5">Cần thanh toán:</span>
              <span class="fw-bold text-danger fs-5 checkout-total"><%= Number(total || 0).toLocaleString('vi-VN') %> đ</span>
            </div>
            
            <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm d-flex justify-content-center align-items-center transition hover-lift" type="submit">
              Xác Nhan Đặt Hàng <i class="bi bi-chevron-right ms-2 fs-5"></i>
            </button>
            <div class="text-center mt-2 small text-muted">
              <i class="bi bi-shield-check text-success me-1"></i> Thông tin của bạn được bảo mật an toàn.
            </div>
          </form>
        </div>
      </div>
    </div>
  <% } %>
</main>
<style>
  .hover-lift:hover { transform: translateY(-3px); }
  .transition { transition: all 0.3s ease; }
  .hover-danger:hover { background-color: #dc3545 !important; color: white !important; opacity: 1; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    function updateCartTotals() {
      let total = 0;
      document.querySelectorAll('.app-quantity-form').forEach(form => {
        const row = form.closest('.cart-item-row');
        if (!row) return;
        const price = Number(row.dataset.price || 0);
        const qty = Number(form.querySelector('input[name="so_luong"]').value || 1);
        const subtotal = price * qty;
        
        // Update item subtotal
        const itemSubtotalEl = row.querySelector('.item-subtotal');
        if (itemSubtotalEl) {
            itemSubtotalEl.innerHTML = subtotal.toLocaleString('vi-VN') + ' <small class="text-decoration-underline fs-6 mt-1">đ</small>';
        }
        total += subtotal;
      });
      
      // Update cart total
      const cartTotalEl = document.querySelector('.cart-total');
      if (cartTotalEl) {
          cartTotalEl.innerHTML = total.toLocaleString('vi-VN') + ' <small class="text-muted fs-5 align-text-top text-decoration-underline ms-1">đ</small>';
      }
      
      // Update checkout total
      const checkoutTotalEl = document.querySelector('.checkout-total');
      if (checkoutTotalEl) {
          checkoutTotalEl.innerHTML = total.toLocaleString('vi-VN') + ' đ';
      }
    }

    document.querySelectorAll('.app-quantity-form').forEach(form => {
      const input = form.querySelector('input[name="so_luong"]');
      const min = parseInt(input.min || 1);
      
      async function submitChange(newQty) {
          try {
              input.disabled = true;
              
              const body = new URLSearchParams();
              body.set('so_luong', String(newQty));
              body.set('_method', 'PUT');
              
              const res = await fetch(form.action, {
                  method: 'POST',
                  headers: { 
                      'Content-Type': 'application/x-www-form-urlencoded',
                      'Accept': 'application/json' 
                  },
                  body: body.toString()
              });
              
              if (res.ok) {
                  input.value = newQty;
                  updateCartTotals();
              } else {
                  console.error('Update failed');
                  input.value = parseInt(input.defaultValue) || min;
              }
          } catch(e) {
              console.error(e);
          } finally {
              input.disabled = false;
          }
      }

      form.querySelector('.btn-decrease').addEventListener('click', (e) => {
        e.preventDefault();
        let val = parseInt(input.value) || min;
        if (val > min) {
          submitChange(val - 1);
        }
      });
  
      form.querySelector('.btn-increase').addEventListener('click', (e) => {
        e.preventDefault();
        let val = parseInt(input.value) || min;
        submitChange(val + 1);
      });
      
      input.addEventListener('change', (e) => {
         let val = parseInt(input.value);
         if (val >= min) {
             submitChange(val);
         } else {
             input.value = min;
             submitChange(min);
         }
      });
    });
  });
</script>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
