<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="container py-4 mb-2">
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="row g-0 align-items-center position-relative">
      <!-- Decorative background element -->
      <div class="position-absolute top-0 end-0 bg-danger bg-opacity-10 rounded-circle" style="width: 300px; height: 300px; margin-top: -100px; margin-right: -100px; filter: blur(40px); z-index: 0"></div>
      
      <div class="col-lg-7 p-4 p-md-5 position-relative" style="z-index: 1">
        <h1 class="h2 fw-bold text-dark mb-3 lh-sm"><%= pageHeading %></h1>
        <p class="text-secondary fs-5 mb-4"><%= pageLead %></p>
        <form class="bg-light p-2 rounded-pill shadow-sm border border-light" method="get" action="<%= basePath || '/san-pham' %>">
          <% if (categoryId) { %><input type="hidden" name="the_loai_id" value="<%= categoryId %>" /><% } %>
          <div class="input-group border-0 align-items-center">
            <span class="input-group-text bg-transparent border-0 text-muted ps-3"><i class="bi bi-search fs-5"></i></span>
            <input class="form-control border-0 shadow-none bg-transparent px-2" type="text" name="q" value="<%= q || '' %>" placeholder="Tìm kiếm nhân vật, mô hình bạn yêu thích..." />
            <button class="btn pm-btn-red rounded-pill px-4 py-2 fw-bold transition hover-lift text-white" type="submit">Tìm kiếm <i class="bi bi-arrow-right ms-1"></i></button>
          </div>
        </form>
      </div>
      <div class="col-lg-5 text-center d-none d-lg-block p-4 position-relative" style="z-index: 1">
        <img class="img-fluid img-hover-scale transition" style="max-height: 240px; object-fit: contain; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));" src="/assets/img/hero.png" alt="PMFigure - Figure anime và mô hình sưu tầm" />
      </div>
    </div>
  </div>
</section>

<main class="container pb-5">
  <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
    <h2 class="h4 fw-bold m-0 text-dark d-flex align-items-center">
      <div class="bg-danger rounded-pill me-3" style="width: 6px; height: 28px;"></div>
      <%= category ? category.ten : 'Tất cả sản phẩm' %>
    </h2>
    <span class="badge bg-light text-dark border shadow-sm rounded-pill fw-medium px-3 py-2">
      <i class="bi bi-box-seam text-danger me-1"></i> Mục lục
    </span>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="alert alert-secondary">Chưa có sản phẩm.</div>
  <% } else { %>
    <div class="row g-3">
      <% products.forEach((p) => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card product-card h-100">
            <a class="text-decoration-none" href="/san-pham/<%= p.id %>">
              <div class="overflow-hidden bg-light" style="aspect-ratio: 1 / 1;">
                <% if (p.hinh_anh) { %>
                  <img
                    class="card-img-top h-100 w-100"
                    style="object-fit: cover;"
                    src="<%= p.hinh_anh.startsWith('/') ? p.hinh_anh : ('/uploads/' + p.hinh_anh) %>"
                    alt="<%= p.ten %>"
                  />
                <% } else { %>
                  <div class="h-100 w-100 bg-light"></div>
                <% } %>
              </div>
              <div class="card-body d-flex flex-column p-2 p-md-3 text-body" style="min-height: 100px;">
                <div
                  class="fw-semibold small"
                  style="min-height: 2.5rem; line-height: 1.25rem; overflow: hidden; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;"
                ><%= p.ten %></div>
                <div
                  class="text-muted small"
                  style="min-height: 1.25rem; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;"
                ><%= p.theLoai ? p.theLoai.ten : '' %></div>
                <div class="mt-auto pt-1 pt-md-2 price"><%= Number(p.gia).toLocaleString('vi-VN') %> đ</div>
              </div>
            </a>
            <div class="card-footer bg-white border-0 pt-0">
              <% if (user) { %>
                <button class="btn btn-sm pm-btn-red w-100 js-quickadd" data-product-id="<%= p.id %>">Chọn mua</button>
              <% } else { %>
                <a class="btn btn-sm btn-outline-secondary w-100" href="/dang-nhap">Đăng nhập để mua</a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
    <div class="text-muted small fw-medium text-uppercase letter-spacing-1">Trang hiện tại: <span class="badge bg-danger rounded-pill fs-6 px-3 py-1 ms-1"><%= page %></span></div>
    <ul class="pagination pagination-sm m-0 gap-2">
      <li class="page-item <%= page > 1 ? '' : 'disabled' %>">
        <% if (page > 1) { %>
          <a class="page-link rounded-pill px-4 border-0 shadow-sm bg-white text-dark fw-medium transition hover-lift" href="<%= basePath || '/san-pham' %>?<%= new URLSearchParams({ the_loai_id: categoryId || '', q: q || '', page: String(page - 1), pageSize: String(pageSize) }).toString() %>"><i class="bi bi-arrow-left me-2"></i>Trước</a>
        <% } else { %>
          <span class="page-link rounded-pill px-4 border-0 bg-light text-muted fw-medium"><i class="bi bi-arrow-left me-2"></i>Trước</span>
        <% } %>
      </li>
      
      <li class="page-item <%= hasNext ? '' : 'disabled' %>">
        <% if (hasNext) { %>
          <a class="page-link rounded-pill px-4 border-0 shadow-sm bg-white text-dark fw-medium transition hover-lift" href="<%= basePath || '/san-pham' %>?<%= new URLSearchParams({ the_loai_id: categoryId || '', q: q || '', page: String(page + 1), pageSize: String(pageSize) }).toString() %>">Sau<i class="bi bi-arrow-right ms-2"></i></a>
        <% } else { %>
          <span class="page-link rounded-pill px-4 border-0 bg-light text-muted fw-medium">Sau<i class="bi bi-arrow-right ms-2"></i></span>
        <% } %>
      </li>
    </ul>
  </div>
</main>

<div class="modal fade" id="quickAddModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
      <div class="modal-header bg-white border-bottom-0 pt-4 pb-2 px-4 position-relative">
        <div class="position-absolute top-0 start-0 w-100 bg-danger" style="height: 4px;"></div>
        <h5 class="modal-title fw-bold text-dark d-flex align-items-center"><i class="bi bi-cart-plus-fill text-danger fs-4 me-2"></i> Thêm nhanh vào giỏ</h5>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Đóng"></button>
      </div>
      <div class="modal-body px-4 py-3">
        <div id="qaError" class="alert alert-danger d-none border-0 rounded-3 shadow-sm text-sm"></div>
        <form id="qaForm" class="vstack gap-4">
          <input type="hidden" name="product_id" id="qaProductId" />
          <div>
            <label class="form-label fw-semibold text-muted small text-uppercase letter-spacing-1">Tùy chọn phiên bản</label>
            <div class="input-group shadow-sm rounded-3 overflow-hidden border border-light">
                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-funnel"></i></span>
                <select class="form-select border-0 bg-light py-2 text-dark fw-medium shadow-none" name="variant_id" id="qaVariant" required></select>
            </div>
          </div>
          <div>
            <label class="form-label fw-semibold text-muted small text-uppercase letter-spacing-1">Số lượng mua</label>
            <div class="input-group shadow-sm rounded-3 overflow-hidden border border-light" style="max-width: 160px;">
                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-123"></i></span>
                <input class="form-control border-0 bg-light py-2 text-center fw-bold shadow-none" type="number" name="so_luong" id="qaQty" min="1" value="1" />
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer bg-light border-top-0 pt-3 pb-4 px-4 d-flex justify-content-end gap-2 mt-2">
        <button type="button" class="btn btn-white border rounded-pill px-4 fw-medium transition" data-bs-dismiss="modal">Hủy bỏ</button>
        <button type="button" class="btn pm-btn-red rounded-pill px-4 fw-bold shadow-sm transition hover-lift text-white d-flex align-items-center" id="qaSubmit">
          Xác nhận <i class="bi bi-check2-circle ms-2 fs-5"></i>
        </button>
      </div>
    </div>
  </div>
</div>
<style>
  .img-hover-scale:hover { transform: scale(1.05); }
  .hover-lift:hover { transform: translateY(-3px); }
  .transition { transition: all 0.3s ease; }
  .letter-spacing-1 { letter-spacing: 1px; }
  .btn-white { background-color: white; color: #333; }
  .btn-white:hover { background-color: #f8f9fa; color: black; }
</style>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
