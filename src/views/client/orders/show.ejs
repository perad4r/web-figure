<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-4">
  <h1 class="h4 mb-3">Đơn hàng #<%= order.id %></h1>

  <div class="mb-3">
    <div>
      <span class="text-muted">Trạng thái:</span>
      <span class="badge <%= statusBadge(order.status) %>"><%= statusLabel(order.status) %></span>
    </div>
    <div><span class="text-muted">Tổng:</span> <%= Number(order.gia || 0).toLocaleString('vi-VN') %> đ</div>
  </div>

  <div class="d-flex gap-2 mb-3">
    <% if ([0,1].includes(order.status)) { %>
      <form method="post" action="/lich-su-don-hang/<%= order.id %>/huy">
        <input type="hidden" name="_method" value="PATCH" />
        <button class="btn btn-sm btn-outline-danger" type="submit">Huỷ đơn</button>
      </form>
    <% } %>
    <% if (order.status === 3) { %>
      <form method="post" action="/lich-su-don-hang/<%= order.id %>/da-nhan">
        <input type="hidden" name="_method" value="PATCH" />
        <button class="btn btn-sm btn-outline-success" type="submit">Đã nhận hàng</button>
      </form>
    <% } %>
    <% if (order.status === 0 && payosEnabled) { %>
      <a class="btn btn-sm btn-success" href="/thanh-toan/payos/<%= order.id %>">Thanh toán ngay</a>
    <% } %>
  </div>

  <h2 class="h6">Chi tiết</h2>
  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr>
          <th>Sản phẩm</th>
          <th>Biến thể</th>
          <th class="text-end">Giá</th>
          <th class="text-end">SL</th>
        </tr>
      </thead>
      <tbody>
        <% (order.details || []).forEach((d) => { %>
          <tr>
            <td><%= d.product?.ten || 'SP' %></td>
            <td class="text-muted">Tùy chọn nội bộ</td>
            <td class="text-end"><%= Number(d.gia || 0).toLocaleString('vi-VN') %> đ</td>
            <td class="text-end"><%= d.so_luong %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
