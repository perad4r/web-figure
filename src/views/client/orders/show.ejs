<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-5 max-w-4xl mx-auto" style="max-width: 900px;">
  <!-- Header -->
  <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
    <div class="d-flex align-items-center gap-3">
      <a href="/lich-su-don-hang" class="btn btn-light rounded-circle p-2 d-flex align-items-center justify-content-center text-secondary border hover-shadow transition" style="width: 40px; height: 40px;">
        <i class="bi bi-arrow-left"></i>
      </a>
      <h1 class="h3 fw-bold mb-0 text-dark">Chi tiết đơn hàng #<span class="text-danger"><%= order.id %></span></h1>
    </div>
    <span class="badge <%= statusBadge(order.status) %> fs-6 px-3 py-2 rounded-pill fw-medium"><%= statusLabel(order.status) %></span>
  </div>

  <div class="row g-4 mb-4">
    <!-- Order Summary Card -->
    <div class="col-md-7 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
              <i class="bi bi-info-circle-fill"></i>
            </div>
            <h5 class="fw-bold mb-0">Thông tin tóm tắt</h5>
          </div>
          
          <div class="ms-5 ps-1">
            <div class="row mb-2">
              <div class="col-sm-4 text-muted small text-uppercase fw-semibold">Tổng giá trị:</div>
              <div class="col-sm-8 text-danger fw-bold fs-5"><%= Number(order.gia || 0).toLocaleString('vi-VN') %> đ</div>
            </div>
            <div class="row mb-2">
              <div class="col-sm-4 text-muted small text-uppercase text-nowrap fw-semibold">Thời gian tạo:</div>
              <div class="col-sm-8 text-dark fw-medium">
                <%= new Date(order.created_at || Date.now()).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions Card -->
    <div class="col-md-5 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 bg-light">
        <div class="card-body p-4 d-flex flex-column justify-content-center gap-2">
          <h6 class="fw-bold text-muted mb-3 text-uppercase small letter-spacing-1">Thao tác hỗ trợ</h6>
          
          <% let hasAction = false; %>
          <% if ([0,1].includes(order.status)) { hasAction = true; %>
              <button type="button" class="btn btn-outline-danger bg-white w-100 rounded-pill fw-medium shadow-sm transition hover-danger" data-bs-toggle="modal" data-bs-target="#cancelOrderModal">
                <i class="bi bi-x-circle me-1"></i> Yêu cầu hủy đơn
              </button>
              
              <!-- Cancel Order Confirmation Modal -->
              <div class="modal fade" id="cancelOrderModal" tabindex="-1" aria-labelledby="cancelOrderModalLabel" aria-hidden="true" style="text-align: left;">
                <div class="modal-dialog modal-dialog-centered">
                  <div class="modal-content border-0 shadow rounded-4 overflow-hidden">
                    <div class="modal-header bg-danger bg-opacity-10 border-bottom-0 pb-3 pt-4 px-4">
                      <h5 class="modal-title fw-bold text-danger d-flex align-items-center" id="cancelOrderModalLabel">
                          <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i> Xác nhận hủy đơn hàng
                      </h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 text-dark fs-6">
                      Bạn có chắc chắn muốn hủy bỏ đơn hàng <strong>#<%= order.id %></strong> này không?<br>
                      <span class="text-muted small mt-2 d-block">Lưu ý: Hành động này không thể hoàn tác sau khi đã thực hiện.</span>
                    </div>
                    <div class="modal-footer bg-light border-top-0 p-3 d-flex justify-content-between">
                      <button type="button" class="btn btn-outline-secondary rounded-pill px-4 fw-medium border shadow-sm transition hover-lift" data-bs-dismiss="modal">Không, giữ lại</button>
                      <form method="post" action="/lich-su-don-hang/<%= order.id %>/huy" class="m-0">
                        <input type="hidden" name="_method" value="PATCH" />
                        <button class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm transition hover-lift" type="submit">
                          Đồng ý hủy đơn
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
          <% } %>
          
          <% if (order.status === 3) { hasAction = true; %>
            <form method="post" action="/lich-su-don-hang/<%= order.id %>/da-nhan" class="w-100">
              <input type="hidden" name="_method" value="PATCH" />
              <button class="btn btn-success w-100 rounded-pill fw-bold shadow-sm transition hover-lift text-white" type="submit">
                <i class="bi bi-check-circle-fill me-1"></i> Đã nhận được hàng
              </button>
            </form>
          <% } %>
          
          <% if (order.status === 0 && payosEnabled) { hasAction = true; %>
            <a class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm transition hover-lift text-white" href="/thanh-toan/payos/<%= order.id %>">
              <i class="bi bi-credit-card me-1"></i> Thanh toán ngay
            </a>
          <% } %>
          
          <% if (!hasAction) { %>
            <div class="text-center text-muted small py-3">
              <i class="bi bi-shield-check fs-2 d-block mb-1 text-success opacity-50"></i>
              Không có thao tác khả dụng
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Order Items Table -->
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
      <h5 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-primary"></i>Danh sách sản phẩm</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light text-muted small text-uppercase">
            <tr>
              <th class="ps-4 fw-medium border-0">Sản phẩm</th>
              <th class="fw-medium border-0">Phân loại</th>
              <th class="text-end fw-medium border-0">Đơn giá</th>
              <th class="text-end pe-4 fw-medium border-0">Số lượng</th>
            </tr>
          </thead>
          <tbody class="border-top-0">
            <% (order.details || []).forEach((d) => { %>
              <tr>
                <td class="ps-4 py-3">
                  <div class="d-flex align-items-center">
                    <div class="bg-light rounded p-2 me-3 text-muted d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                      <i class="bi bi-image fs-4 opacity-50"></i>
                    </div>
                    <div class="fw-semibold text-dark"><%= d.product?.ten || 'Sản phẩm không xác định' %></div>
                  </div>
                </td>
                <td class="py-3">
                  <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">Tùy chọn tiêu chuẩn</span>
                </td>
                <td class="text-end py-3 fw-medium">
                  <%= Number(d.gia || 0).toLocaleString('vi-VN') %> đ
                </td>
                <td class="text-end pe-4 py-3 fw-bold">
                  <%= d.so_luong %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
<style>
  .hover-shadow:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important; }
  .transition { transition: all 0.3s ease; }
  .hover-lift:hover { transform: translateY(-2px); }
  .letter-spacing-1 { letter-spacing: 1px; }
  .hover-danger:hover { background-color: #dc3545 !important; color: white !important; }
</style>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
