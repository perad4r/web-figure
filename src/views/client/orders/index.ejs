<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-4">
  <h1 class="h4 mb-3">Lịch sử đơn hàng</h1>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-secondary">Chưa có đơn hàng.</div>
  <% } else { %>
    <div class="list-group">
      <% orders.forEach((o) => { %>
        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="/lich-su-don-hang/<%= o.id %>">
          <div>#<%= o.id %> - <%= Number(o.gia || 0).toLocaleString('vi-VN') %> đ</div>
          <div class="text-muted small">
            <span class="badge <%= statusBadge(o.status) %>"><%= statusLabel(o.status) %></span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
