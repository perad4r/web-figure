<% const pageSeo = typeof seo !== 'undefined' && seo ? seo : {}; %>
<%
  const safeArray = (value) => (Array.isArray(value) ? value : []);
  const toImageSrc = (image) => {
    if (!image) return '';
    if (/^https?:\/\//i.test(image)) return image;
    if (String(image).startsWith('/')) return image;
    return `/uploads/${image}`;
  };

  const sections = safeArray(categoriesWithProducts).filter(
    (category) => Array.isArray(category.products) && category.products.length
  );
  const heroCategory = sections[0] || null;
  const heroProducts = heroCategory ? heroCategory.products.slice(0, 5) : safeArray(featuredProducts).slice(0, 5);
  const heroSectionTitle = heroCategory?.ten || 'Sản phẩm nổi bật';
  const heroSectionLink = heroCategory ? `/san-pham?the_loai_id=${heroCategory.id}` : '/san-pham';
  const categoryCards = safeArray(categoriesWithProducts).slice(0, 6);
  const heroBannerItems = safeArray(heroBanners);
  const promoCardItems = safeArray(promoCards);
  const brandLogoItems = safeArray(brandLogos);
  const testimonialItems = safeArray(testimonials);
  const galleryImageItems = safeArray(galleryImages);
%>
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageSeo.title || title || 'PMFigure' %></title>
    <meta
      name="description"
      content="<%= pageSeo.description || 'PMFigure - cửa hàng figure anime, mô hình sưu tầm và quà tặng dành cho người yêu thích nhân vật.' %>"
    />
    <% if (pageSeo.keywords) { %>
      <meta name="keywords" content="<%= pageSeo.keywords %>" />
    <% } %>
    <meta property="og:locale" content="<%= pageSeo.ogLocale || 'vi_VN' %>" />
    <meta property="og:type" content="<%= pageSeo.ogType || 'website' %>" />
    <meta property="og:title" content="<%= pageSeo.title || title || 'PMFigure' %>" />
    <meta
      property="og:description"
      content="<%= pageSeo.description || 'PMFigure - cửa hàng figure anime, mô hình sưu tầm và quà tặng dành cho người yêu thích nhân vật.' %>"
    />
    <meta property="og:site_name" content="PMFigure" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= pageSeo.title || title || 'PMFigure' %>" />
    <meta
      name="twitter:description"
      content="<%= pageSeo.description || 'PMFigure - cửa hàng figure anime, mô hình sưu tầm và quà tặng dành cho người yêu thích nhân vật.' %>"
    />
    <% if (pageSeo.canonicalUrl) { %>
      <link rel="canonical" href="<%= pageSeo.canonicalUrl %>" />
      <meta property="og:url" content="<%= pageSeo.canonicalUrl %>" />
    <% } %>
    <link rel="icon" href="/favicons/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
    <link rel="manifest" href="/favicons/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/tailwind.css" />
    <link rel="stylesheet" href="/vendor/swiper/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script defer src="/assets/js/app.js"></script>
    <style>
      :root {
        --pm-bg: #f8f5f0;
        --pm-surface: #ffffff;
        --pm-surface-soft: #faf7f2;
        --pm-primary: #f06292;
        --pm-primary-strong: #db2777;
        --pm-text: #1f1f1f;
        --pm-muted: #6f665f;
        --pm-border: rgba(31, 31, 31, 0.08);
      }

      html {
        scroll-behavior: smooth;
      }

      body.pm-home {
        background: var(--pm-bg);
        color: var(--pm-text);
        font-family: 'Roboto', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .pm-home .pm-header .col-6.col-md-3.col-lg-2 > a {
        gap: 0.5rem !important;
      }

      .pm-home .pm-header .col-6.col-md-3.col-lg-2 > a img {
        height: 28px !important;
        width: auto;
      }

      .pm-home .pm-header .col-6.col-md-3.col-lg-2 > a .fw-bold {
        font-size: 1rem;
        line-height: 1.1;
      }

      .pm-home h1,
      .pm-home h2,
      .pm-home h3,
      .pm-home h4,
      .pm-home h5,
      .pm-home h6,
      .font-headline {
        font-family: 'Playfair Display', serif;
      }

      .pm-no-scrollbar::-webkit-scrollbar {
        display: none;
      }

      .pm-no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      .pm-line-clamp-2 {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
      }

      .pm-hero-swiper {
        overflow: hidden;
      }

      .pm-hero-swiper .swiper-slide {
        position: relative;
      }

      .pm-hero-pagination {
        bottom: 1.5rem !important;
      }

      .pm-hero-pagination .swiper-pagination-bullet {
        width: 0.5rem;
        height: 0.5rem;
        margin: 0 0.25rem !important;
        background: rgba(212, 212, 216, 0.8);
        opacity: 1;
        transition: background-color 0.2s ease, transform 0.2s ease;
      }

      .pm-hero-pagination .swiper-pagination-bullet-active {
        background: #db2777;
        transform: scale(1.1);
      }

      .pm-testimonial-swiper {
        overflow: hidden;
      }

      .pm-testimonial-swiper .swiper-slide {
        height: auto;
      }

      .pm-testimonial-swiper .swiper-button-prev,
      .pm-testimonial-swiper .swiper-button-next {
        color: #db2777;
      }

      .pm-testimonial-swiper .swiper-button-prev::after,
      .pm-testimonial-swiper .swiper-button-next::after {
        font-size: 1.25rem;
        font-weight: 700;
      }

      .pm-testimonial-pagination {
        position: static;
        margin-top: 1rem;
      }

      .pm-testimonial-pagination .swiper-pagination-bullet {
        background: rgba(212, 212, 216, 0.9);
        opacity: 1;
      }

      .pm-testimonial-pagination .swiper-pagination-bullet-active {
        background: #db2777;
      }

      .pm-marquee {
        animation: pm-scroll 15s linear infinite;
      }

      @keyframes pm-scroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
    </style>
  </head>
  <body class="pm-home pb-20 md:pb-0">
    <%- include('./partials/nav') %>

    <main class="mx-auto max-w-7xl space-y-24 px-4 sm:px-6 lg:px-8">
      <section class="relative overflow-hidden rounded-[28px] bg-white shadow-sm ring-1 ring-black/5">
        <div id="heroBannerTrack" class="swiper pm-hero-swiper">
          <div class="swiper-wrapper">
            <% (heroBannerItems.length ? heroBannerItems : ['']).forEach((banner) => { %>
            <div class="swiper-slide">
              <img
                class="h-[300px] w-full object-cover md:h-[500px]"
                alt="high quality soft lighting photography of an anime figure collection displayed elegantly on clean white shelves with soft pink ambient lighting"
                src="<%= banner %>"
              />
              <div class="absolute inset-0 flex items-center bg-gradient-to-r from-black/65 via-black/20 to-transparent">
                <div class="max-w-lg p-8 md:p-16">
                  <h1 class="mb-4 text-4xl font-bold leading-tight text-white md:text-6xl">
                    The Art of<br />
                    <span class="text-pink-300">Collecting</span>
                  </h1>
                  <p class="mb-8 text-lg text-white/85">Curated figures for the discerning collector.</p>
                  <a
                    href="/san-pham"
                    class="inline-flex items-center rounded-full bg-pink-600 px-8 py-3 font-semibold text-white shadow-lg shadow-pink-600/20 transition-colors hover:bg-pink-700"
                  >
                    Explore Gallery
                  </a>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
          <div class="swiper-pagination pm-hero-pagination"></div>
        </div>
      </section>

      <section class="mt-3 grid gap-6 md:grid-cols-2">
        <% promoCardItems.forEach((card) => { %>
          <a href="<%= card.href %>" class="group relative block h-[250px] overflow-hidden rounded-[24px] shadow-sm ring-1 ring-black/5">
            <img
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              alt="<%= card.title %>"
              src="<%= card.image %>"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent p-6">
              <div class="flex h-full flex-col justify-end">
                <h2 class="text-2xl font-bold text-white"><%= card.title %></h2>
                <p class="mt-1 text-sm font-medium text-pink-200"><%= card.subtitle %></p>
              </div>
            </div>
          </a>
        <% }) %>
      </section>

      <section class="mt-3">
        <div class="mb-8 flex items-end justify-between gap-4">
          <h2 class="text-2xl font-bold text-zinc-900">Danh Mục</h2>
          <a class="text-sm font-medium text-pink-600 transition-colors hover:text-pink-700" href="/san-pham">
            Xem tất cả
          </a>
        </div>

        <div class="flex gap-8 overflow-x-auto pb-4 pm-no-scrollbar">
          <% categoryCards.forEach((category) => {
               const categoryImage =
                 category.products && category.products.length > 0 && category.products[0].hinh_anh
                   ? toImageSrc(category.products[0].hinh_anh)
                   : '';
          %>
            <a
              href="/san-pham?the_loai_id=<%= category.id %>"
              class="group flex min-w-[80px] flex-col items-center gap-3 text-center"
            >
              <div class="h-20 w-20 rounded-full bg-zinc-50 p-1 shadow-sm ring-2 ring-zinc-200 transition-all group-hover:ring-pink-200">
                <% if (categoryImage) { %>
                  <img class="h-full w-full rounded-full object-cover" src="<%= categoryImage %>" alt="<%= category.ten %>" />
                <% } else { %>
                  <div class="h-full w-full rounded-full bg-zinc-200"></div>
                <% } %>
              </div>
              <span class="line-clamp-1 text-center text-sm font-medium text-zinc-600 transition-colors group-hover:text-pink-600">
                <%= category.ten %>
              </span>
            </a>
          <% }) %>
        </div>
      </section>

      <section class="mt-3 border-y border-black/10 py-8">
        <div class="mx-auto flex max-w-5xl items-center gap-8 overflow-x-auto px-4 pm-no-scrollbar">
          <% brandLogoItems.forEach((brand) => { %>
            <img
              alt="<%= brand.alt %>"
              class="h-12 object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0"
              src="<%= brand.src %>"
            />
          <% }) %>
        </div>
      </section>

      <% if (heroProducts.length) { %>
        <section class="mt-3 space-y-6">
          <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
            <div class="inline-flex max-w-full rounded-r-full bg-pink-600 px-4 py-2 text-base font-bold text-white shadow-md sm:px-6 sm:text-lg">
              <%= heroSectionTitle %>
            </div>
            <a
              href="<%= heroSectionLink %>"
              class="text-sm font-medium text-pink-600 transition-colors hover:text-pink-700 sm:pr-4"
            >
              Xem thêm <%= heroSectionTitle %> &rarr;
            </a>
          </div>

          <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
            <% heroProducts.forEach((product) => { %>
              <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition-shadow hover:shadow-md">
                <a href="/san-pham/<%= product.id %>" class="flex h-full flex-col text-inherit">
                  <div class="relative overflow-hidden bg-zinc-100 pt-[100%]">
                    <% if (product.hinh_anh) { %>
                      <img
                        alt="<%= product.ten %>"
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        src="<%= toImageSrc(product.hinh_anh) %>"
                      />
                    <% } else { %>
                      <div class="absolute inset-0 h-full w-full bg-zinc-200"></div>
                    <% } %>
                  </div>

                  <div class="flex flex-1 flex-col p-4">
                    <h3 class="pm-line-clamp-2 mb-2 text-sm text-zinc-600">
                      <%= product.ten %>
                    </h3>
                    <div class="mt-auto">
                      <div class="mb-1 text-xs text-zinc-500">Tồn kho: <%= Number(product.ton_kho || 0) %></div>
                      <div class="mb-3 text-lg font-bold text-pink-600">
                        <%= Number(product.gia || 0).toLocaleString('vi-VN') %>đ
                      </div>
                      <button
                        type="button"
                        class="pointer-events-none flex w-full items-center justify-center gap-2 rounded-lg bg-pink-50 py-2 font-medium text-pink-600 transition-colors group-hover:bg-pink-600 group-hover:text-white"
                      >
                        <i class="bi bi-bag"></i>
                        Chọn mua
                      </button>
                    </div>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="mt-3 grid gap-6 border-t border-black/10 py-12 md:grid-cols-2 lg:grid-cols-4">
        <div class="flex flex-col items-center px-4 text-center">
          <i class="bi bi-box-seam mb-3 text-4xl text-pink-600"></i>
          <h3 class="mb-2 font-bold text-zinc-900">ĐẶT HÀNG / ĐẶT HÀNG TRƯỚC</h3>
          <p class="text-sm text-zinc-600">Nhận tìm kiếm và đặt hàng các loại sản phẩm theo yêu cầu</p>
        </div>
        <div class="flex flex-col items-center px-4 text-center">
          <i class="bi bi-patch-check mb-3 text-4xl text-pink-600"></i>
          <h3 class="mb-2 font-bold text-zinc-900">HÀNG CHÍNH HÃNG</h3>
          <p class="text-sm text-zinc-600">Cam kết hàng chính hãng 100% được đặt trực tiếp từ nhà phân phối</p>
        </div>
        <div class="flex flex-col items-center px-4 text-center">
          <i class="bi bi-truck mb-3 text-4xl text-pink-600"></i>
          <h3 class="mb-2 font-bold text-zinc-900">SHIP TOÀN QUỐC</h3>
          <p class="text-sm text-zinc-600">Nhận ship hàng các đơn vị vận chuyển như Viettelpost, SPX</p>
        </div>
        <div class="flex flex-col items-center px-4 text-center">
          <i class="bi bi-arrow-repeat mb-3 text-4xl text-pink-600"></i>
          <h3 class="mb-2 font-bold text-zinc-900">BẢO HÀNH 1 ĐỔI 1</h3>
          <p class="text-sm text-zinc-600">Nhận đổi hàng mới trong trường hợp lỗi từ nhà sản xuất</p>
        </div>
      </section>

      <% if (testimonialItems.length) { %>
        <section class="relative mt-3 overflow-hidden rounded-[28px] bg-white px-6 py-12 shadow-sm ring-1 ring-black/5">
          <div class="mb-10 text-center">
            <h2 class="text-3xl font-bold text-zinc-900">Cảm Nhận Khách Hàng</h2>
          </div>

          <div id="testimonialTrack" class="swiper pm-testimonial-swiper relative z-10">
            <div class="swiper-wrapper">
            <% testimonialItems.forEach((review) => { %>
              <div class="swiper-slide text-center">
                <div class="mx-auto mb-4 h-24 w-24 overflow-hidden rounded-full border-4 border-white shadow-sm">
                  <img alt="<%= review.user %>" class="h-full w-full object-cover" src="<%= review.avatar %>" />
                </div>
                <h3 class="mb-2 text-lg font-bold text-zinc-900"><%= review.user %></h3>
                <p class="mb-4 italic text-zinc-600">" <%= review.comment %> "</p>
                <div class="flex justify-center gap-1 text-amber-500">
                  <% for (let i = 0; i < 5; i += 1) { %>
                    <i class="bi bi-star-fill"></i>
                  <% } %>
                </div>
              </div>
            <% }) %>
            </div>
            <div class="swiper-pagination pm-testimonial-pagination"></div>
          </div>

          <button
            id="testimonialPrev"
            type="button"
            class="absolute left-4 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white text-zinc-700 shadow-md transition-colors hover:text-pink-600"
            aria-label="Previous review"
          >
            <i class="bi bi-chevron-left"></i>
          </button>
          <button
            id="testimonialNext"
            type="button"
            class="absolute right-4 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white text-zinc-700 shadow-md transition-colors hover:text-pink-600"
            aria-label="Next review"
          >
            <i class="bi bi-chevron-right"></i>
          </button>
        </section>
      <% } %>

      <section class="overflow-hidden">
        <div class="flex w-max pm-marquee">
          <% [0, 1].forEach(() => { %>
            <div class="flex shrink-0">
              <% galleryImageItems.forEach((image, index) => { %>
                <div class="w-72 p-1 md:w-80 lg:w-96">
                  <img
                    alt="Gallery <%= index + 1 %>"
                    class="h-64 w-full rounded-xl object-cover"
                    src="<%= image %>"
                  />
                </div>
              <% }) %>
            </div>
          <% }) %>
        </div>
      </section>
    </main>

    <%- include('./partials/footer') %>

    <nav class="fixed bottom-0 left-0 z-50 flex w-full items-center justify-around border-t border-black/5 bg-white/95 px-4 py-3 shadow-[0_-4px_20px_rgba(240,98,146,0.08)] backdrop-blur-lg md:hidden">
      <a
        href="/"
        class="flex flex-col items-center justify-center rounded-xl bg-pink-50 px-4 py-1 text-pink-600 transition-transform active:scale-90"
      >
        <i class="bi bi-house-fill mb-1 text-xl"></i>
        <span class="text-[10px] font-medium">Home</span>
      </a>
      <a href="/san-pham" class="flex flex-col items-center justify-center text-zinc-400 transition-colors hover:text-pink-400">
        <i class="bi bi-grid mb-1 text-xl"></i>
        <span class="text-[10px] font-medium">Category</span>
      </a>
      <a href="/giohangs" class="relative flex flex-col items-center justify-center text-zinc-400 transition-colors hover:text-pink-400">
        <i class="bi bi-bag mb-1 text-xl"></i>
        <span class="text-[10px] font-medium">Cart</span>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="absolute right-2 top-0 flex h-4 w-4 items-center justify-center rounded-full bg-pink-600 text-[10px] font-bold text-white">
            <%= cartCount %>
          </span>
        <% } %>
      </a>
      <a
        href="<%= (typeof user !== 'undefined' && user) ? '/ho-so' : '/dang-nhap' %>"
        class="flex flex-col items-center justify-center text-zinc-400 transition-colors hover:text-pink-400"
      >
        <i class="bi bi-person mb-1 text-xl"></i>
        <span class="text-[10px] font-medium">Profile</span>
      </a>
    </nav>

    <script defer src="/vendor/swiper/swiper-bundle.min.js"></script>
    <script defer src="/assets/js/home.js"></script>
    <%- include('./partials/foot') %>
  </body>
</html>
