<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container py-5 d-flex justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 w-100" style="max-width: 600px;">
    <div class="text-center mb-4">
      <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
        <i class="bi bi-person-lines-fill fs-2"></i>
      </div>
      <h1 class="h3 fw-bold mb-0">Hồ sơ cá nhân</h1>
      <p class="text-muted small mt-1">Cập nhật thông tin để nhận hàng thuận tiện hơn</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger border-0 d-flex align-items-center rounded-3 shadow-sm bg-danger bg-opacity-10 text-danger">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div><%= error %></div>
      </div>
    <% } %>

    <form method="post" action="/ho-so" class="row g-4 mt-1">
      <input type="hidden" name="_method" value="PUT" />
      
      <div class="col-md-6">
        <label class="form-label fw-semibold text-dark">Họ và Tên</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-person"></i></span>
          <input class="form-control bg-light border-start-0 rounded-end-3 py-2 px-3" name="ten" value="<%= user.ten %>" required />
        </div>
      </div>
      
      <div class="col-md-6">
        <label class="form-label fw-semibold text-dark">Số điện thoại</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-telephone"></i></span>
          <input class="form-control bg-light border-start-0 rounded-end-3 py-2 px-3" type="tel" name="phone" pattern="[0-9]{9,11}" title="Nhập 9-11 chữ số" value="<%= user.phone || '' %>" />
        </div>
      </div>
      
      <div class="col-12">
        <label class="form-label fw-semibold text-dark">Địa chỉ giao hàng</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted align-items-start pt-3"><i class="bi bi-geo-alt"></i></span>
          <textarea class="form-control bg-light border-start-0 rounded-end-3 py-2 px-3" name="address" rows="3"><%= user.address || '' %></textarea>
        </div>
      </div>
      
      <div class="col-12 mt-4 pt-3 border-top d-flex justify-content-end gap-2">
        <a href="/" class="btn btn-light rounded-pill px-4 fw-medium">Hủy</a>
        <button class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm transition hover-lift text-white" type="submit">Lưu Thay Đổi</button>
      </div>
    </form>
  </div>
</main>
<style>
  .hover-lift:hover { transform: translateY(-2px); }
  .transition { transition: all 0.3s ease; }
</style>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>
