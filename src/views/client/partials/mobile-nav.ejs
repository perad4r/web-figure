<style>
  @media (max-width: 767.98px) {
    body {
      padding-bottom: 5.5rem;
    }
  }

  .pm-mobile-nav {
    z-index: 1050;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 -4px 20px rgba(240, 98, 146, 0.08);
    backdrop-filter: blur(16px);
  }

  .pm-mobile-nav-link {
    min-width: 64px;
    border-radius: 0.75rem;
    color: #a1a1aa;
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .pm-mobile-nav-link:hover,
  .pm-mobile-nav-link:focus {
    color: #f06292;
  }

  .pm-mobile-nav-link:active {
    transform: scale(0.9);
  }

  .pm-mobile-nav-link.is-active {
    background: #fdf2f8;
    color: #db2777;
  }

  .pm-mobile-nav-icon {
    font-size: 1.25rem;
    line-height: 1;
  }

  .pm-mobile-nav-label {
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
  }

  .pm-mobile-nav-badge {
    top: 0;
    right: 0.35rem;
    width: 1rem;
    height: 1rem;
    background: #db2777;
    font-size: 10px;
    line-height: 1rem;
  }
</style>

<%
  const mobileNavPath = typeof currentPath !== 'undefined' ? currentPath : '';
  const isHome = mobileNavPath === '/';
  const isProducts = mobileNavPath === '/san-pham' || mobileNavPath.startsWith('/san-pham/');
  const isCart = mobileNavPath === '/giohangs';
  const isProfile = mobileNavPath === '/ho-so' || mobileNavPath === '/dang-nhap';
%>

<nav class="pm-mobile-nav position-fixed bottom-0 start-0 w-100 d-md-none">
  <div class="d-flex align-items-center justify-content-around px-3 py-3">
  <a
    href="/"
    class="pm-mobile-nav-link d-flex flex-column align-items-center justify-content-center gap-1 px-3 py-1 <%= isHome ? 'is-active' : '' %>"
  >
    <i class="bi bi-house-fill pm-mobile-nav-icon"></i>
    <span class="pm-mobile-nav-label">Home</span>
  </a>
  <a
    href="/san-pham"
    class="pm-mobile-nav-link d-flex flex-column align-items-center justify-content-center gap-1 px-3 py-1 <%= isProducts ? 'is-active' : '' %>"
  >
    <i class="bi bi-grid pm-mobile-nav-icon"></i>
    <span class="pm-mobile-nav-label">Category</span>
  </a>
  <a href="/giohangs" class="pm-mobile-nav-link position-relative d-flex flex-column align-items-center justify-content-center gap-1 px-3 py-1 <%= isCart ? 'is-active' : '' %>">
    <i class="bi bi-bag pm-mobile-nav-icon"></i>
    <span class="pm-mobile-nav-label">Cart</span>
    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
      <span class="pm-mobile-nav-badge position-absolute d-inline-flex align-items-center justify-content-center rounded-circle fw-bold text-white">
        <%= cartCount %>
      </span>
    <% } %>
  </a>
  <a
    href="<%= (typeof user !== 'undefined' && user) ? '/ho-so' : '/dang-nhap' %>"
    class="pm-mobile-nav-link d-flex flex-column align-items-center justify-content-center gap-1 px-3 py-1 <%= isProfile ? 'is-active' : '' %>"
  >
    <i class="bi bi-person pm-mobile-nav-icon"></i>
    <span class="pm-mobile-nav-label">Profile</span>
  </a>
  </div>
</nav>
