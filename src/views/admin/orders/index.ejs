<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Đơn hàng</h1>
    <form method="get" action="/admin/orders" class="d-flex gap-2">
      <input class="form-control form-control-sm" style="width: 120px" name="q" value="<%= q || '' %>" placeholder="mã đơn" />
      <input class="form-control form-control-sm" style="width: 120px" name="status" value="<%= status === null ? '' : status %>" placeholder="trạng thái" />
      <button class="btn btn-sm btn-outline-secondary" type="submit">Lọc</button>
    </form>
  </div>

  <% if (!rows || rows.length === 0) { %>
    <div class="alert alert-secondary">Trống.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>Người dùng</th>
            <th class="text-end">Tổng</th>
            <th>Trạng thái</th>
            <th>PayOS</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((o) => { %>
            <tr>
              <td><%= o.id %></td>
              <td><%= o.user ? o.user.email : '' %></td>
              <td class="text-end"><%= Number(o.gia || 0).toLocaleString('vi-VN') %></td>
              <td><%= o.status %></td>
              <td><%= o.payos_status || '' %></td>
              <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/orders/<%= o.id %>">Xem</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted small">Trang <%= page %></div>
    <div class="d-flex gap-2">
      <% if (page > 1) { %>
        <a class="btn btn-sm btn-outline-secondary" href="/admin/orders?<%= new URLSearchParams({ q: q || '', status: status === null ? '' : String(status), page: String(page - 1), pageSize: String(pageSize) }).toString() %>">Trước</a>
      <% } %>
      <% if (hasNext) { %>
        <a class="btn btn-sm btn-outline-secondary" href="/admin/orders?<%= new URLSearchParams({ q: q || '', status: status === null ? '' : String(status), page: String(page + 1), pageSize: String(pageSize) }).toString() %>">Sau</a>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/foot') %>
