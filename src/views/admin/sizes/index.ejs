<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container-fluid pb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0 text-dark">Quản lý Kích cỡ</h1>
    <a class="btn btn-primary rounded-pill px-4 fw-medium shadow-sm transition hover-lift" href="/admin/sizes/new"><i class="bi bi-rulers me-2"></i>Thêm Kích cỡ</a>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-bottom py-3 px-4">
      <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
        <form method="get" action="/admin/sizes" class="d-flex gap-2">
          <input type="hidden" name="deleted" value="<%= showDeleted ? '1' : '' %>" />
          <div class="input-group" style="min-width: 300px;">
             <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
             <input class="form-control bg-light border-0 shadow-none" name="q" value="<%= q || '' %>" placeholder="Tìm kiếm kích cỡ..." />
             <button class="btn btn-secondary border-0 fw-medium" type="submit">Tìm</button>
          </div>
        </form>
        <div class="d-flex gap-2">
            <a class="btn btn-sm <%= !showDeleted ? 'btn-dark' : 'btn-light border' %> rounded-pill px-3 fw-medium" href="/admin/sizes">Đang dùng</a>
            <a class="btn btn-sm <%= showDeleted ? 'btn-dark' : 'btn-light border' %> rounded-pill px-3 fw-medium" href="/admin/sizes?deleted=1">Đã xóa</a>
        </div>
      </div>
    </div>

    <div class="card-body p-0">
      <% if (!rows || rows.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-rulers fs-1 d-block mb-2 opacity-50"></i>
            Chưa có dữ liệu kích cỡ.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table-modern">
            <thead>
              <tr>
                <th width="80">#</th>
                <th>Tên kích cỡ</th>
                <th class="text-center">Tình trạng</th>
                <th class="text-end">Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((r) => { %>
                <tr>
                  <td class="fw-semibold text-muted">#<%= r.id %></td>
                  <td class="fw-bold text-dark"><span class="badge bg-light text-dark border px-3 py-2"><%= r.ten %></span></td>
                  <td class="text-center">
                    <% if (!r.deleted_at) { %>
                        <span class="badge bg-success border border-success px-2 py-1 rounded-pill">Hoạt động</span>
                    <% } else { %>
                        <span class="badge bg-secondary border border-secondary px-2 py-1 rounded-pill">Đã xóa</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <div class="d-flex gap-2 justify-content-end">
                      <% if (!r.deleted_at) { %>
                        <a class="btn btn-sm btn-light border text-primary transition hover-lift" href="/admin/sizes/<%= r.id %>/edit" title="Sửa">
                          <i class="bi bi-pencil-square"></i>
                        </a>
                        <form method="post" action="/admin/sizes/<%= r.id %>" class="m-0">
                          <input type="hidden" name="_method" value="DELETE" />
                          <button class="btn btn-sm btn-light border text-danger transition hover-lift" type="submit" title="Xóa">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <form method="post" action="/admin/sizes/<%= r.id %>/restore" class="m-0">
                          <input type="hidden" name="_method" value="PATCH" />
                          <button class="btn btn-sm btn-success rounded-pill px-3 fw-medium transition hover-lift text-white" type="submit">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Khôi phục
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
    
    <div class="card-footer bg-white border-top py-3 px-4 d-flex justify-content-between align-items-center">
      <div class="text-muted small fw-medium">Trang <%= page %></div>
      <div class="d-flex gap-2">
        <% if (page > 1) { %>
          <a class="btn btn-sm btn-light border rounded-pill px-3 fw-medium" href="/admin/sizes?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', q: q || '', page: String(page - 1), pageSize: String(pageSize) }).toString() %>"><i class="bi bi-chevron-left"></i> Trước</a>
        <% } %>
        <% if (hasNext) { %>
          <a class="btn btn-sm btn-light border rounded-pill px-3 fw-medium" href="/admin/sizes?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', q: q || '', page: String(page + 1), pageSize: String(pageSize) }).toString() %>">Sau <i class="bi bi-chevron-right"></i></a>
        <% } %>
      </div>
    </div>
  </div>
</main>
<style>
  .hover-lift:hover { transform: translateY(-2px); }
  .transition { transition: all 0.2s ease; }
</style>

<%- include('../partials/foot') %>
