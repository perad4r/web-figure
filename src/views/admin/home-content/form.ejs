<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 720px;">
  <h1 class="h4 mb-3"><%= title %></h1>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form
    method="post"
    action="<%= row ? `/admin/home-content/${row.id}?_method=PUT` : '/admin/home-content' %>"
    enctype="multipart/form-data"
    class="vstack gap-3"
  >
    <div>
      <label class="form-label">Section</label>
      <select name="section" class="form-select" required>
        <% sections.forEach((section) => { %>
          <option value="<%= section %>" <%= defaultSection === section ? 'selected' : '' %>><%= section %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <label class="form-label">Thứ tự</label>
      <input class="form-control" type="number" min="0" name="position" value="<%= row ? row.position : 0 %>" />
    </div>

    <div>
      <label class="form-label">Tiêu đề / Alt</label>
      <input class="form-control" type="text" name="label" value="<%= row?.label || '' %>" />
    </div>

    <div>
      <label class="form-label">Phụ đề</label>
      <input class="form-control" type="text" name="subtitle" value="<%= row?.subtitle || '' %>" />
    </div>

    <div>
      <label class="form-label">Đường dẫn</label>
      <input class="form-control" type="text" name="link_url" value="<%= row?.link_url || '' %>" />
    </div>

    <div>
      <label class="form-label">Tải ảnh lên</label>
      <input class="form-control" type="file" name="image" accept="image/*" />
      <% if (row?.image_url) { %>
        <img src="<%= row.image_url %>" alt="<%= row.label || 'preview' %>" style="height:80px; width:120px; margin-top:8px; object-fit:cover;" />
      <% } %>
    </div>

    <div>
      <label class="form-label">Hoặc URL ảnh ngoài</label>
      <input class="form-control" type="text" name="image_url_manual" value="<%= row?.image_url || '' %>" />
    </div>

    <div>
      <label class="form-label">Nội dung testimonial</label>
      <textarea class="form-control" name="comment" rows="3"><%= row?.extra?.comment || '' %></textarea>
    </div>

    <div class="form-check">
      <input
        class="form-check-input"
        type="checkbox"
        name="is_active"
        value="1"
        id="isActive"
        <%= (!row || row.is_active) ? 'checked' : '' %>
      />
      <label class="form-check-label" for="isActive">Hiển thị</label>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Lưu</button>
      <a class="btn btn-outline-secondary" href="/admin/home-content">Hủy</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
