<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container-fluid pb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0 text-dark">Quản lý Đánh giá</h1>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-bottom py-3 px-4">
      <div class="d-flex justify-content-end align-items-center">
        <div class="d-flex gap-2">
            <a class="btn btn-sm <%= !showDeleted ? 'btn-dark' : 'btn-light border' %> rounded-pill px-3 fw-medium" href="/admin/reviews">Đang hiển thị</a>
            <a class="btn btn-sm <%= showDeleted ? 'btn-dark' : 'btn-light border' %> rounded-pill px-3 fw-medium" href="/admin/reviews?deleted=1">Đã ẩn/xóa</a>
        </div>
      </div>
    </div>

    <div class="card-body p-0">
      <% if (!rows || rows.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-star flex-shrink-0 fs-1 d-block mb-2 opacity-50"></i>
            Chưa có đánh giá nào.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table-modern">
            <thead>
              <tr>
                <th width="80">#</th>
                <th width="20%">Sản phẩm</th>
                <th width="15%">Người dùng</th>
                <th width="120" class="text-center">Đánh giá</th>
                <th>Nội dung</th>
                <th class="text-end">Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((r) => { %>
                <tr>
                  <td class="fw-semibold text-muted">#<%= r.id %></td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-box text-secondary"></i>
                      <span class="text-dark fw-medium text-truncate d-inline-block" style="max-width: 15vw;" title="<%= r.product?.ten || '' %>"><%= r.product?.ten || 'Không rõ SP' %></span>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-light text-dark border"><i class="bi bi-person me-1"></i><%= r.user?.email || 'Khách' %></span>
                  </td>
                  <td class="text-center">
                     <div class="d-flex justify-content-center text-warning" style="font-size: 0.85rem;">
                       <% for(let i=0; i<5; i++) { %>
                           <i class="bi bi-star<%= i < r.rating ? '-fill' : '' %>"></i>
                       <% } %>
                     </div>
                  </td>
                  <td><p class="mb-0 text-muted small" style="max-width: 300px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= r.danh_gia %></p></td>
                  <td class="text-end">
                    <div class="d-flex gap-2 justify-content-end">
                      <% if (!showDeleted) { %>
                        <a class="btn btn-sm btn-light border text-primary transition hover-lift" href="/admin/reviews/<%= r.id %>/edit" title="Sửa nội dung">
                          <i class="bi bi-pencil-square"></i>
                        </a>
                        <form method="post" action="/admin/reviews/<%= r.id %>?_method=DELETE" class="m-0">
                          <input type="hidden" name="_method" value="DELETE" />
                          <button class="btn btn-sm btn-light border text-danger transition hover-lift" type="submit" title="Ẩn/Xóa đánh giá">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <form method="post" action="/admin/reviews/<%= r.id %>/restore?_method=PATCH" class="m-0">
                          <input type="hidden" name="_method" value="PATCH" />
                          <button class="btn btn-sm btn-success rounded-pill px-3 fw-medium transition hover-lift text-white" type="submit">
                            <i class="bi bi-eye me-1"></i> Hiển thị lại
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
    
    <div class="card-footer bg-white border-top py-3 px-4 d-flex justify-content-between align-items-center">
      <div class="text-muted small fw-medium">Trang <%= page %></div>
      <div class="d-flex gap-2">
        <% if (page > 1) { %>
          <a class="btn btn-sm btn-light border rounded-pill px-3 fw-medium" href="/admin/reviews?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', page: String(page - 1), pageSize: String(pageSize) }).toString() %>"><i class="bi bi-chevron-left"></i> Trước</a>
        <% } %>
        <% if (hasNext) { %>
          <a class="btn btn-sm btn-light border rounded-pill px-3 fw-medium" href="/admin/reviews?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', page: String(page + 1), pageSize: String(pageSize) }).toString() %>">Sau <i class="bi bi-chevron-right"></i></a>
        <% } %>
      </div>
    </div>
  </div>
</main>
<style>
  .hover-lift:hover { transform: translateY(-2px); }
  .transition { transition: all 0.2s ease; }
</style>

<%- include('../partials/foot') %>
