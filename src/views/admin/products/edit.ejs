<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 820px;">
  <h1 class="h4 mb-3">Edit Product</h1>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/products/<%= row.id %>" class="vstack gap-2" enctype="multipart/form-data">
    <input type="hidden" name="_method" value="PUT" />
    <div>
      <label class="form-label">Name</label>
      <input class="form-control" name="ten" value="<%= row.ten %>" required />
    </div>
    <div class="row g-2">
      <div class="col-md-6">
        <label class="form-label">Category</label>
        <select class="form-select" name="the_loai_id" required>
          <% categories.forEach((c) => { %>
            <option value="<%= c.id %>" <%= c.id === row.the_loai_id ? 'selected' : '' %>><%= c.ten %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Price</label>
        <input class="form-control" type="number" name="gia" value="<%= row.gia %>" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Stock</label>
        <input class="form-control" type="number" name="ton_kho" value="<%= row.ton_kho %>" />
      </div>
    </div>
    <div>
      <label class="form-label">Replace Image</label>
      <input class="form-control" type="file" name="image" />
      <% if (row.hinh_anh) { %>
        <div class="form-text">Current: <code><%= row.hinh_anh %></code></div>
      <% } %>
    </div>
    <div>
      <label class="form-label">Description</label>
      <textarea class="form-control" name="mo_ta"><%= row.mo_ta || '' %></textarea>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Save</button>
      <a class="btn btn-outline-secondary" href="/admin/products">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>

