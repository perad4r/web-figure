<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 820px;">
  <h1 class="h4 mb-3">Thêm sản phẩm</h1>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/products" class="vstack gap-2" enctype="multipart/form-data">
    <div>
      <label class="form-label">Tên</label>
      <input class="form-control" name="ten" required />
    </div>
    <div class="row g-2">
      <div class="col-md-6">
        <label class="form-label">Danh mục</label>
        <select class="form-select" name="the_loai_id" required>
          <option value="">--</option>
          <% categories.forEach((c) => { %>
            <option value="<%= c.id %>"><%= c.ten %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Giá</label>
        <input class="form-control" type="number" name="gia" value="0" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Tồn kho</label>
        <input class="form-control" type="number" name="ton_kho" value="0" />
      </div>
    </div>
    <div>
      <label class="form-label">Ảnh</label>
      <input class="form-control" type="file" name="image" />
      <div class="form-text">Tùy chọn. Lưu dưới `/uploads/products/...`</div>
    </div>
    <div>
      <label class="form-label">Mô tả</label>
      <textarea class="form-control" name="mo_ta"></textarea>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Tạo</button>
      <a class="btn btn-outline-secondary" href="/admin/products">Hủy</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
