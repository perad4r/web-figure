  <aside class="sidebar d-flex flex-column" id="sidebar">
    <div class="d-flex align-items-center px-4 py-3 border-bottom" style="height: 64px;">
      <a class="text-decoration-none fw-bold fs-5 text-dark" href="/admin/dashboard">
        <div class="d-flex align-items-center">
            <div class="bg-primary text-white rounded d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                <i class="bi bi-layers-half fs-6"></i>
            </div>
            <span>PMFigure <span class="text-primary">Admin</span></span>
        </div>
      </a>
    </div>
    
    <div class="flex-grow-1 overflow-auto py-3">
      <div class="small fw-bold text-muted text-uppercase mb-2 px-4 mt-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Tổng quan</div>
      <a class="nav-item-link" href="/admin/dashboard">
        <i class="bi bi-speedometer2"></i> Bảng điều khiển
      </a>
      
      <% if (user && user.role === 0) { %>
      <div class="small fw-bold text-muted text-uppercase mb-2 px-4 mt-4" style="font-size: 0.7rem; letter-spacing: 0.5px;">Sản phẩm</div>
      <a class="nav-item-link" href="/admin/categories">
        <i class="bi bi-tags"></i> Danh mục
      </a>
      <a class="nav-item-link" href="/admin/products">
        <i class="bi bi-box-seam"></i> Sản phẩm
      </a>
      <a class="nav-item-link" href="/admin/variants">
        <i class="bi bi-boxes"></i> Biến thể (SP)
      </a>
      <% } %>

      <div class="small fw-bold text-muted text-uppercase mb-2 px-4 mt-4" style="font-size: 0.7rem; letter-spacing: 0.5px;">Kinh doanh</div>
      <a class="nav-item-link" href="/admin/orders">
        <i class="bi bi-bag"></i> Đơn hàng
      </a>
      <a class="nav-item-link" href="/admin/customers">
        <i class="bi bi-people"></i> Khách hàng
      </a>
      <a class="nav-item-link" href="/admin/reviews">
        <i class="bi bi-star-half"></i> Đánh giá
      </a>
      
      <% if (user && user.role === 0) { %>
      <div class="small fw-bold text-muted text-uppercase mb-2 px-4 mt-4" style="font-size: 0.7rem; letter-spacing: 0.5px;">Hệ thống & Web</div>
      <a class="nav-item-link" href="/admin/home-content">
        <i class="bi bi-layout-text-window"></i> Banner & Giao diện
      </a>
      <a class="nav-item-link" href="/admin/users">
        <i class="bi bi-person-badge"></i> Quản trị viên
      </a>
      <% } %>
    </div>
  </aside>

  <div class="main-content">
    <header class="topbar justify-content-between">
      <div class="d-flex align-items-center">
        <button class="btn btn-light rounded-circle p-2 d-lg-none me-3" id="sidebarToggle" style="width: 40px; height: 40px;">
          <i class="bi bi-list fs-5"></i>
        </button>
        <!-- Search bar stub -->
        <div class="d-none d-md-flex align-items-center bg-light rounded-pill px-3 py-2 border" style="width: 300px;">
            <i class="bi bi-search text-muted me-2"></i>
            <input type="text" class="form-control border-0 bg-transparent p-0 shadow-none text-sm" placeholder="Tìm kiếm nhanh..." style="font-size: 0.875rem;">
        </div>
      </div>
      
      <div class="d-flex align-items-center gap-3">
        <a class="btn btn-light btn-sm rounded-pill fw-medium px-3 text-secondary" href="/san-pham" target="_blank">
          <i class="bi bi-box-arrow-up-right me-1"></i> Mở trang web
        </a>
        <div class="dropdown">
          <button class="btn btn-light border d-flex align-items-center gap-2 rounded-pill px-1 py-1 dropdown-toggle shadow-sm" type="button" data-bs-toggle="dropdown" style="background: #fff;">
            <span class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center ms-1" style="width: 32px; height: 32px; font-weight: bold; font-size: 14px;">A</span>
            <span class="fw-semibold d-none d-md-block me-1" style="font-size: 0.875rem;"><%= user ? user.ten : 'Admin' %></span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2 rounded-4">
            <li class="px-3 py-2 border-bottom mb-1 bg-light text-center">
                <div class="fw-bold"><%= user ? user.ten : 'Admin' %></div>
                <div class="text-muted small"><%= user && user.role === 0 ? 'Quản trị viên cấp cao' : 'Nhân viên' %></div>
            </li>
            <li><a class="dropdown-item py-2" href="/ho-so"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
            <li>
              <form method="post" action="/dang-xuat" class="m-0">
                <button class="dropdown-item text-danger d-flex align-items-center py-2" type="submit">
                  <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </button>
              </form>
            </li>
          </ul>
        </div>
      </div>
    </header>

    <div class="content-wrapper">
      <% if (flash && flash.message) { %>
        <div class="alert alert-<%= flash.type || 'info' %> alert-dismissible fade show border-0 shadow-sm rounded-4" role="alert">
          <div class="d-flex align-items-center">
            <% if(flash.type === 'success') { %><i class="bi bi-check-circle-fill text-success fs-4 me-3"></i><% } else if(flash.type === 'danger') { %><i class="bi bi-exclamation-triangle-fill text-danger fs-4 me-3"></i><% } else { %><i class="bi bi-info-circle-fill text-info fs-4 me-3"></i><% } %>
            <div class="fw-medium"><%= flash.message %></div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>
