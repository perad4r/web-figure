<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 720px;">
  <h1 class="h4 mb-3">Sửa người dùng</h1>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/users/<%= row.id %>" class="vstack gap-2">
    <input type="hidden" name="_method" value="PUT" />
    <div>
      <label class="form-label">Tên</label>
      <input class="form-control" name="ten" value="<%= row.ten || '' %>" required />
    </div>
    <div>
      <label class="form-label">Email</label>
      <input class="form-control" name="email" type="email" value="<%= row.email || '' %>" required />
    </div>
    <div>
      <label class="form-label">Mật khẩu (để trống nếu giữ nguyên)</label>
      <input class="form-control" name="password" type="password" />
    </div>
    <div>
      <label class="form-label">Số điện thoại</label>
      <input class="form-control" name="phone" value="<%= row.phone || '' %>" />
    </div>
    <div>
      <label class="form-label">Địa chỉ</label>
      <textarea class="form-control" name="address"><%= row.address || '' %></textarea>
    </div>
    <div>
      <label class="form-label">Vai trò</label>
      <select class="form-select" name="role" required>
        <option value="0" <%= Number(row.role) === 0 ? 'selected' : '' %>>Admin</option>
        <option value="1" <%= Number(row.role) === 1 ? 'selected' : '' %>>Khách</option>
        <option value="2" <%= Number(row.role) === 2 ? 'selected' : '' %>>Nhân viên</option>
      </select>
    </div>
    <div class="form-check">
      <input class="form-check-input" type="checkbox" name="status" value="1" <%= row.status ? 'checked' : '' %> />
      <label class="form-check-label">Đang dùng</label>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Lưu</button>
      <a class="btn btn-outline-secondary" href="/admin/users">Hủy</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
