<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="container pb-5">
  <h1 class="h4 mb-3">Dashboard</h1>
  <div class="row g-3">
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Users</div>
        <div class="h4 mb-0"><%= stats.users %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Categories</div>
        <div class="h4 mb-0"><%= stats.categories %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Products</div>
        <div class="h4 mb-0"><%= stats.products %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Variants</div>
        <div class="h4 mb-0"><%= stats.variants %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Orders</div>
        <div class="h4 mb-0"><%= stats.orders %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Reviews</div>
        <div class="h4 mb-0"><%= stats.reviews %></div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/foot') %>
