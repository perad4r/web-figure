<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="container pb-5">
  <h1 class="h4 mb-3">Bảng điều khiển</h1>
  <div class="row g-3">
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Người dùng</div>
        <div class="h4 mb-0"><%= stats.users %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Danh mục</div>
        <div class="h4 mb-0"><%= stats.categories %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Sản phẩm</div>
        <div class="h4 mb-0"><%= stats.products %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Biến thể</div>
        <div class="h4 mb-0"><%= stats.variants %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Đơn hàng</div>
        <div class="h4 mb-0"><%= stats.orders %></div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="border rounded p-3">
        <div class="text-muted">Đánh giá</div>
        <div class="h4 mb-0"><%= stats.reviews %></div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/foot') %>
