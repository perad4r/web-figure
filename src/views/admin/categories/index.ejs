<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Danh mục</h1>
    <div class="d-flex gap-2">
      <form method="get" action="/admin/categories" class="d-flex gap-2">
        <% if (showDeleted) { %><input type="hidden" name="deleted" value="1" /><% } %>
        <input class="form-control form-control-sm" name="q" value="<%= q || '' %>" placeholder="search..." />
        <button class="btn btn-sm btn-outline-secondary" type="submit">Tìm</button>
      </form>
      <a class="btn btn-sm btn-outline-secondary" href="/admin/categories">Đang dùng</a>
      <a class="btn btn-sm btn-outline-secondary" href="/admin/categories?deleted=1">Đã xóa</a>
      <a class="btn btn-primary btn-sm" href="/admin/categories/new">Thêm mới</a>
    </div>
  </div>

  <% if (!rows || rows.length === 0) { %>
    <div class="alert alert-secondary">Trống.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>Tên</th>
            <th>Trạng thái</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((r) => { %>
            <tr>
              <td><%= r.id %></td>
              <td><%= r.ten %></td>
              <td><%= r.trang_thai ? 'active' : 'inactive' %></td>
              <td class="text-end">
                <% if (!showDeleted) { %>
                  <a class="btn btn-sm btn-outline-secondary" href="/admin/categories/<%= r.id %>/edit">Sửa</a>
                  <form method="post" action="/admin/categories/<%= r.id %>" class="d-inline">
                    <input type="hidden" name="_method" value="DELETE" />
                    <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                  </form>
                <% } else { %>
                  <form method="post" action="/admin/categories/<%= r.id %>/restore" class="d-inline">
                    <input type="hidden" name="_method" value="PATCH" />
                    <button class="btn btn-sm btn-outline-success" type="submit">Khôi phục</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted small">Trang <%= page %></div>
    <div class="d-flex gap-2">
      <% if (page > 1) { %>
        <a class="btn btn-sm btn-outline-secondary" href="/admin/categories?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', q: q || '', page: String(page - 1), pageSize: String(pageSize) }).toString() %>">Trước</a>
      <% } %>
      <% if (hasNext) { %>
        <a class="btn btn-sm btn-outline-secondary" href="/admin/categories?<%= new URLSearchParams({ deleted: showDeleted ? '1' : '', q: q || '', page: String(page + 1), pageSize: String(pageSize) }).toString() %>">Sau</a>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/foot') %>
