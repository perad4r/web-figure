<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 820px;">
  <h1 class="h4 mb-3">Sửa biến thể</h1>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/variants/<%= row.id %>" class="vstack gap-2" enctype="multipart/form-data">
    <input type="hidden" name="_method" value="PUT" />
    <div class="alert alert-info mb-0">
      Màu sắc và kích cỡ đã được tắt khỏi giao diện. Bản ghi này vẫn giữ dữ liệu nền để hệ thống cũ hoạt động ổn định.
    </div>
    <div class="row g-2">
      <div class="col-md-8">
        <label class="form-label">Sản phẩm</label>
        <select class="form-select" name="hang_id" required>
          <% products.forEach((p) => { %>
            <option value="<%= p.id %>" <%= p.id === row.hang_id ? 'selected' : '' %>><%= p.ten %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Loại tùy chọn</label>
        <input class="form-control" value="Tự động mặc định" disabled />
      </div>
    </div>
    <div class="row g-2">
      <div class="col-md-6">
        <label class="form-label">Thay ảnh</label>
        <input class="form-control" type="file" name="image" />
        <% if (row.hinh_anh) { %><div class="form-text">Current: <code><%= row.hinh_anh %></code></div><% } %>
      </div>
      <div class="col-md-3">
        <label class="form-label">Giá</label>
        <input class="form-control" type="number" name="gia" value="<%= row.gia %>" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Tồn kho</label>
        <input class="form-control" type="number" name="ton_kho" value="<%= row.ton_kho %>" />
      </div>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Lưu</button>
      <a class="btn btn-outline-secondary" href="/admin/variants">Hủy</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
