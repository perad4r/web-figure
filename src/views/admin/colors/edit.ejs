<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container pb-5" style="max-width: 720px;">
  <h1 class="h4 mb-3">Edit Color</h1>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <form method="post" action="/admin/colors/<%= row.id %>" class="vstack gap-2">
    <input type="hidden" name="_method" value="PUT" />
    <div>
      <label class="form-label">Name</label>
      <input class="form-control" name="ten" value="<%= row.ten %>" required />
    </div>
    <div>
      <label class="form-label">Hex</label>
      <input class="form-control" name="hex_code" value="<%= row.hex_code || '' %>" />
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Save</button>
      <a class="btn btn-outline-secondary" href="/admin/colors">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>

